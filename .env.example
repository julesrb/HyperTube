# Database
POSTGRES_USER=hypertube
POSTGRES_PASSWORD=changeme
POSTGRES_DB=hypertube
DATABASE_URL=postgres://hypertube:changeme@postgres:5432/hypertube?sslmode=disable

# Frontend
NEXT_PUBLIC_API_URL=http://localhost:8080/api/v1

# JWT
# Generate one locally, for example: openssl rand -base64 32
JWT_SECRET=

# TMDb
TMDB_API_KEY=

# C411
C411_API_KEY=

# 42 OAuth
FORTYTWO_CLIENT_ID=
FORTYTWO_CLIENT_SECRET=
FORTYTWO_REDIRECT_URL=http://localhost:8080/api/v1/auth/42/callback
FRONTEND_AUTH_CALLBACK_URL=http://localhost:4200/auth/callback

# GitHub OAuth
GITHUB_CLIENT_ID=
GITHUB_CLIENT_SECRET=
GITHUB_REDIRECT_URL=http://localhost:8080/api/v1/auth/github/callback

# Email (password reset)
BREVO_API_KEY=
MAIL_FROM_EMAIL=
MAIL_FROM_NAME=Hypertube
PASSWORD_RESET_URL=http://localhost:4200/{locale}/reset-password
PASSWORD_RESET_TTL=30m

# VPN (optional, used with --profile vpn)
VPN_PROVIDER=
WIREGUARD_PRIVATE_KEY=
WIREGUARD_ADDRESSES=
