#!/usr/bin/env bash

set -uo pipefail

STORY_ROOT="$(cd -- "$(dirname -- "${BASH_SOURCE[0]}")" && pwd)"
REPO_ROOT="$(cd -- "$STORY_ROOT/.." && pwd)"
SCRIPT_DIR="$STORY_ROOT/scripts"

BASE_URL="${BASE_URL:-http://localhost:8080}"
BASE_URL="${BASE_URL%/}"

SCRIPT_IDS=(
  "user"
  "featured"
  "search-fallback"
  "comments"
  "oauth-token"
  "forty-two-auth"
  "github-auth"
  "forty-two-cli"
  "password-reset"
  "database"
)
SCRIPT_TITLES=(
  "New User Movie Journey"
  "Featured Movie Visitor Journey"
  "Search Fallback Journey"
  "Comment Lifecycle Journey"
  "OAuth2 Token Journey"
  "42 OAuth Safety Journey"
  "GitHub OAuth Safety Journey"
  "Manual 42 CLI Login Journey"
  "Password Reset Journey"
  "Database Snapshot"
)
SCRIPT_FILES=(
  "demo_user_story.sh"
  "demo_featured_movie_story.sh"
  "demo_search_fallback_story.sh"
  "demo_comments_story.sh"
  "demo_oauth_token_story.sh"
  "demo_42_auth_story.sh"
  "demo_github_auth_story.sh"
  "demo_42_cli_login_story.sh"
  "demo_password_reset_story.sh"
  "show_db_contents.sh"
)
SCRIPT_DEPS=(
  "curl jq"
  "curl jq"
  "curl jq"
  "curl jq"
  "curl jq sed"
  "curl jq sed"
  "curl jq sed"
  "curl jq sed"
  "curl jq sed"
  ""
)
SCRIPT_DESCRIPTIONS=(
  "Registers a fresh demo user, logs in, browses movies, searches, opens details, and checks torrents through the API."
  "Starts as an anonymous visitor on featured movies, then signs in when detail and torrent routes require authentication."
  "Demonstrates recovery from a weak search query by trying a backup query and falling back to featured movie data when needed."
  "Signs in, selects a movie, posts a comment, verifies it, edits it, fetches it by ID, and deletes it again."
  "Registers a password user, exchanges credentials through POST /oauth/token, reuses the Bearer token, and demonstrates OAuth2 error bodies."
  "Validates the 42 OAuth start and callback safety paths, including missing provider configuration, state checks, and denied consent."
  "Validates the GitHub OAuth start and callback safety paths, including missing provider configuration, state checks, scopes, and denied consent."
  "Guides a developer through real 42 OAuth consent from the terminal, then uses the returned JWT on a protected movie search."
  "Requests a password reset email, checks account-enumeration-safe responses, and optionally consumes RESET_TOKEN to verify the new password."
  "Prints a readable snapshot of the Hypertube database via Docker Compose or psql. This is a utility, not part of Run All Walkthroughs."
)

WALKTHROUGH_COUNT=9

RESET=""
BOLD=""
DIM=""
RED=""
GREEN=""
YELLOW=""
CYAN=""
REVERSE=""

if [[ -z "${NO_COLOR:-}" && ( -t 1 || "${FORCE_COLOR:-}" == "1" || "${CLICOLOR_FORCE:-}" == "1" ) ]]; then
  RESET=$'\033[0m'
  BOLD=$'\033[1m'
  DIM=$'\033[2m'
  RED=$'\033[31m'
  GREEN=$'\033[32m'
  YELLOW=$'\033[33m'
  CYAN=$'\033[36m'
  REVERSE=$'\033[7m'
fi

usage() {
  cat <<USAGE
Hypertube User Story Runner

Usage:
  user_stories/start_me
  user_stories/start_me --list
  user_stories/start_me --run <story|all>
  user_stories/start_me --help

Stories:
  user              New user registration, login, browse, search, detail, torrents.
  featured          Anonymous featured movie browsing, then authenticated detail access.
  search-fallback   Search recovery flow with backup query and featured fallback.
  comments          Authenticated comment flow, including JWT-owned update/delete checks.
  oauth-token       OAuth2 password grant and bearer-token walkthrough.
  forty-two-auth    42 OAuth route safety and callback validation.
  github-auth       GitHub OAuth route safety and callback validation.
  forty-two-cli     Manual real 42 OAuth login flow from the terminal.
  password-reset    Password reset request and token-consumption walkthrough.
  database          Database snapshot utility.
  all               Run every walkthrough story except the database snapshot.

Environment:
  BASE_URL          API origin. Default: http://localhost:8080
  NO_COLOR=1       Disable color output.
  FORCE_COLOR=1    Force color output.

Interactive controls:
  Up/Down or j/k    Move selection.
  Enter             Run selected item.
  1-9, 0            Jump to a story or utility.
  q or Esc          Quit.
USAGE
}

terminal_width() {
  local width

  width="${COLUMNS:-}"
  if [[ -z "$width" && -t 1 ]] && command -v tput >/dev/null 2>&1; then
    width="$(tput cols 2>/dev/null || true)"
  fi
  if [[ -z "$width" || ! "$width" =~ ^[0-9]+$ ]]; then
    width=88
  fi
  if (( width > 104 )); then
    width=104
  elif (( width < 64 )); then
    width=64
  fi

  printf '%s' "$width"
}

rule() {
  local width

  width="$(terminal_width)"
  printf '%*s\n' "$width" '' | tr ' ' '-'
}

print_wrapped() {
  local indent="$1"
  local color="$2"
  local text="$3"
  local width
  local max_len
  local line=""
  local word

  width="$(terminal_width)"
  max_len=$((width - ${#indent}))
  if (( max_len < 24 )); then
    max_len=24
  fi

  for word in $text; do
    if [[ -z "$line" ]]; then
      line="$word"
    elif (( ${#line} + ${#word} + 1 <= max_len )); then
      line="$line $word"
    else
      printf '%s%b%s%b\n' "$indent" "$color" "$line" "$RESET"
      line="$word"
    fi
  done

  if [[ -n "$line" ]]; then
    printf '%s%b%s%b\n' "$indent" "$color" "$line" "$RESET"
  fi
}

print_header() {
  printf '%b%s%b\n' "${BOLD}${CYAN}" "Hypertube User Story Runner" "$RESET"
  printf '%b%s%b\n' "$DIM" "Interactive walkthrough selection for scripts in user_stories/scripts." "$RESET"
  rule
}

list_stories() {
  local i

  print_header
  printf '  %b%-16s%b %s\n' "$DIM" "BASE_URL" "$RESET" "$BASE_URL"
  printf '  %b%-16s%b %s\n' "$DIM" "Script folder" "$RESET" "$SCRIPT_DIR"
  echo

  for i in "${!SCRIPT_IDS[@]}"; do
    printf '  %b%d. %s%b\n' "$BOLD" "$((i + 1))" "${SCRIPT_TITLES[$i]}" "$RESET"
    printf '     %bID:%b %s\n' "$DIM" "$RESET" "${SCRIPT_IDS[$i]}"
    print_wrapped "     " "" "${SCRIPT_DESCRIPTIONS[$i]}"
    printf '     %bCommand:%b %s\n' "$DIM" "$RESET" "user_stories/scripts/${SCRIPT_FILES[$i]}"
    echo
  done

  printf '  %b%d. Run All Walkthroughs%b\n' "$BOLD" "$((${#SCRIPT_IDS[@]} + 1))" "$RESET"
  print_wrapped "     " "" "Runs the nine user-facing walkthrough stories in order. The database snapshot is excluded because it is an inspection utility."
}

normalize_query() {
  local value="$1"

  value="$(printf '%s' "$value" | tr '[:upper:]' '[:lower:]')"
  value="${value//_/-}"
  value="${value// /-}"
  printf '%s' "$value"
}

resolve_script_index() {
  local query

  query="$(normalize_query "$1")"
  case "$query" in
    1|user|new-user|user-story|registration)
      printf '0'
      ;;
    2|featured|featured-movie|visitor)
      printf '1'
      ;;
    3|search|search-fallback|fallback)
      printf '2'
      ;;
    4|comments|comment|comment-lifecycle|movie-comments)
      printf '3'
      ;;
    5|oauth-token|oauth2|oauth2-token|token|password-grant)
      printf '4'
      ;;
    6|42|forty-two|forty-two-auth|oauth|oauth-safety)
      printf '5'
      ;;
    7|github|github-auth|github-oauth|github-safety)
      printf '6'
      ;;
    8|forty-two-cli|42-cli|manual-42|manual-oauth|cli-login)
      printf '7'
      ;;
    9|password-reset|password|reset|forgot-password)
      printf '8'
      ;;
    10|database|db|snapshot|show-db)
      printf '9'
      ;;
    *)
      return 1
      ;;
  esac
}

missing_dependencies() {
  local deps="$1"
  local dep
  local missing=()

  for dep in $deps; do
    if ! command -v "$dep" >/dev/null 2>&1; then
      missing+=("$dep")
    fi
  done

  if (( ${#missing[@]} > 0 )); then
    printf '%s\n' "${missing[*]}"
    return 1
  fi
}

print_run_banner() {
  local index="$1"

  echo
  rule
  printf '%bRunning:%b %s\n' "${BOLD}${CYAN}" "$RESET" "${SCRIPT_TITLES[$index]}"
  printf '%bPurpose:%b %s\n' "$DIM" "$RESET" "${SCRIPT_DESCRIPTIONS[$index]}"
  printf '%bCommand:%b %s\n' "$DIM" "$RESET" "BASE_URL=$BASE_URL user_stories/scripts/${SCRIPT_FILES[$index]}"
  rule
  echo
}

run_script_index() {
  local index="$1"
  local script_path
  local missing
  local status

  script_path="$SCRIPT_DIR/${SCRIPT_FILES[$index]}"
  if [[ ! -f "$script_path" ]]; then
    printf '%bMissing script file:%b %s\n' "$RED" "$RESET" "$script_path" >&2
    return 66
  fi

  missing="$(missing_dependencies "${SCRIPT_DEPS[$index]}" || true)"
  if [[ -n "$missing" ]]; then
    printf '%bCannot run %s.%b Missing command(s): %s\n' "$RED" "${SCRIPT_TITLES[$index]}" "$RESET" "$missing" >&2
    return 127
  fi

  print_run_banner "$index"
  (
    cd "$REPO_ROOT" || exit 1
    BASE_URL="$BASE_URL" bash "$script_path"
  )
  status=$?

  echo
  if [[ "$status" -eq 0 ]]; then
    printf '%bPASS%b %s completed successfully.\n' "$GREEN" "$RESET" "${SCRIPT_TITLES[$index]}"
  else
    printf '%bFAIL%b %s exited with status %d.\n' "$RED" "$RESET" "${SCRIPT_TITLES[$index]}" "$status"
  fi

  return "$status"
}

run_all_walkthroughs() {
  local i
  local status
  local failed=0
  local passed=0
  local results=()

  for ((i = 0; i < WALKTHROUGH_COUNT; i++)); do
    run_script_index "$i"
    status=$?
    results+=("${SCRIPT_TITLES[$i]}:$status")
    if [[ "$status" -eq 0 ]]; then
      passed=$((passed + 1))
    else
      failed=$((failed + 1))
    fi
  done

  echo
  rule
  printf '%bRun summary%b\n' "${BOLD}${CYAN}" "$RESET"
  for i in "${!results[@]}"; do
    status="${results[$i]##*:}"
    if [[ "$status" -eq 0 ]]; then
      printf '  %bPASS%b %s\n' "$GREEN" "$RESET" "${results[$i]%:*}"
    else
      printf '  %bFAIL%b %s (exit %s)\n' "$RED" "$RESET" "${results[$i]%:*}" "$status"
    fi
  done
  printf '  %bPassed%b %d\n' "$DIM" "$RESET" "$passed"
  printf '  %bFailed%b %d\n' "$DIM" "$RESET" "$failed"

  if [[ "$failed" -ne 0 ]]; then
    return 1
  fi
}

run_requested() {
  local target
  local index
  local run_all_number

  target="${1:-}"
  if [[ -z "$target" ]]; then
    printf 'Missing story name. Run with --list to see available stories.\n' >&2
    return 64
  fi

  run_all_number="$((${#SCRIPT_IDS[@]} + 1))"

  if [[ "$(normalize_query "$target")" == "all" || "$target" == "$run_all_number" ]]; then
    run_all_walkthroughs
    return $?
  fi

  if ! index="$(resolve_script_index "$target")"; then
    printf 'Unknown story: %s\n\n' "$target" >&2
    usage >&2
    return 64
  fi

  run_script_index "$index"
}

option_count() {
  printf '%s' "$((${#SCRIPT_IDS[@]} + 2))"
}

draw_menu() {
  local selected="$1"
  local total_options
  local run_all_index
  local quit_index
  local i
  local label
  local description
  local marker
  local number

  total_options="$(option_count)"
  run_all_index="${#SCRIPT_IDS[@]}"
  quit_index="$((run_all_index + 1))"

  printf '\033[H\033[2J'
  print_header
  printf '  %b%-14s%b %s\n' "$DIM" "BASE_URL" "$RESET" "$BASE_URL"
  printf '  %b%-14s%b %s\n' "$DIM" "Controls" "$RESET" "Up/Down, j/k, Enter, 1-9, 0, q"
  echo

  for ((i = 0; i < total_options; i++)); do
    marker=" "
    number="$((i + 1))"

    if [[ "$i" -lt "${#SCRIPT_IDS[@]}" ]]; then
      label="${SCRIPT_TITLES[$i]}"
      description="${SCRIPT_DESCRIPTIONS[$i]}"
    elif [[ "$i" -eq "$run_all_index" ]]; then
      label="Run All Walkthroughs"
      description="Runs the nine user-facing walkthrough stories in order. The database snapshot stays manual."
    else
      label="Quit"
      description="Leave the user story runner without starting a script."
    fi

    if [[ "$i" -eq "$selected" ]]; then
      marker=">"
      printf '  %b%s %s. %s%b\n' "${REVERSE}${BOLD}" "$marker" "$number" "$label" "$RESET"
      print_wrapped "    " "$CYAN" "$description"
    else
      printf '  %b%s%b %s. %s\n' "$DIM" "$marker" "$RESET" "$number" "$label"
      print_wrapped "    " "$DIM" "$description"
    fi
    echo
  done
}

pause_after_run() {
  if [[ -t 0 && -t 1 ]]; then
    echo
    printf '%bPress Enter to return to the menu.%b' "$DIM" "$RESET"
    IFS= read -r _
  fi
}

interactive_menu() {
  local selected=0
  local key
  local rest
  local total_options
  local run_all_index
  local quit_index

  if [[ ! -t 0 || ! -t 1 ]]; then
    usage >&2
    return 64
  fi

  total_options="$(option_count)"
  run_all_index="${#SCRIPT_IDS[@]}"
  quit_index="$((run_all_index + 1))"

  printf '\033[?25l'
  trap 'printf "\033[?25h"; exit 130' INT TERM
  trap 'printf "\033[?25h"' EXIT

  while true; do
    draw_menu "$selected"
    IFS= read -rsn1 key || return 130

    case "$key" in
      $'\033')
        rest=""
        IFS= read -rsn2 -t 0.05 rest || true
        case "$rest" in
          "[A")
            selected=$(( (selected + total_options - 1) % total_options ))
            ;;
          "[B")
            selected=$(( (selected + 1) % total_options ))
            ;;
          *)
            return 0
            ;;
        esac
        ;;
      k|K)
        selected=$(( (selected + total_options - 1) % total_options ))
        ;;
      j|J)
        selected=$(( (selected + 1) % total_options ))
        ;;
      1|2|3|4|5|6|7|8|9)
        selected=$((key - 1))
        ;;
      0)
        selected=9
        ;;
      q|Q)
        return 0
        ;;
      "")
        printf '\033[?25h'
        if [[ "$selected" -lt "${#SCRIPT_IDS[@]}" ]]; then
          run_script_index "$selected"
          pause_after_run
        elif [[ "$selected" -eq "$run_all_index" ]]; then
          run_all_walkthroughs
          pause_after_run
        elif [[ "$selected" -eq "$quit_index" ]]; then
          return 0
        fi
        printf '\033[?25l'
        ;;
    esac
  done
}

main() {
  case "${1:-}" in
    -h|--help)
      usage
      ;;
    --list|list)
      list_stories
      ;;
    --run|run)
      shift
      run_requested "${1:-}"
      ;;
    "")
      interactive_menu
      ;;
    *)
      run_requested "$1"
      ;;
  esac
}

main "$@"
